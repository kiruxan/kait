{
  "manifest_version": 3,
  "name": "Text Translator",
  "version": "1.1.4",
  "description": "Translate selected text using Grok XAI API with auto-detection of source language",
  "permissions": [
    "activeTab",
    "storage"
  ],
  "background": {
    "service_worker": "background/service-worker.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content/content.js"],
      "css": ["content/content.css"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "options_page": "options/options.html"
}
